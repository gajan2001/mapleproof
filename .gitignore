# Node.js dependencies — installed by npm install on the server, NOT committed
node_modules/

# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (may contain secrets)
.env
.env.local
.env.*.local

# Local data + secrets generated by the server
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.encryption.key
.admin-token

# SSL certificates (generate locally, don't commit)
cert.pem
key.pem
*.pfx

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
.cache/

# Logs
*.log
logs/
